# ─────────────────────────────────────────────────────────────
#  Cockpit OCM-26400 — configuration UNIQUE (ports + paramètres)
#  TOUT est ici : aucun port ni paramètre hardcodé dans le code.
#  Convention : OCM_COCKPIT_* = backend Python · VITE_OCM_COCKPIT_* = frontend
#  Plage de ports HTTP cockpit : 26430–26440
#  Plage de ports OCM IPC (services modèle) : 26400–26420
#  Source de vérité UNIQUE : ce fichier (conforme Besoins/cockpit.md).
# ─────────────────────────────────────────────────────────────

# === Ports HTTP cockpit (plage 26430-26440 — NOUVEAU, déconnecté ancien projet) ===
OCM_COCKPIT_API_PORT=26431
VITE_OCM_COCKPIT_API_PORT=26431
OCM_COCKPIT_DASHBOARD_PORT=26430
VITE_OCM_COCKPIT_DASHBOARD_PORT=26430
OCM_COCKPIT_HMR_PORT=26432
VITE_OCM_COCKPIT_HMR_PORT=26432
OCM_COCKPIT_INFER_PORT=26433
VITE_OCM_COCKPIT_INFER_PORT=26433
OCM_COCKPIT_SG_INFER_PORT=26434
VITE_OCM_COCKPIT_SG_INFER_PORT=26434

# === Orchestrator (agents systems OCM-26400) ===
OCM_COCKPIT_ORCH_PORT=26440
VITE_OCM_COCKPIT_ORCH_PORT=26440
OCM_COCKPIT_ORCH_HOST=127.0.0.1
VITE_OCM_COCKPIT_ORCH_HOST=127.0.0.1

# === Connexion API ===
OCM_COCKPIT_API_HOST=localhost
VITE_OCM_COCKPIT_API_HOST=localhost
OCM_COCKPIT_API_PROTOCOL=http
VITE_OCM_COCKPIT_API_PROTOCOL=http
VITE_OCM_COCKPIT_API_URL=http://localhost:26431

# === OCM-26400 — Ports IPC (services modèle, Besoins/Formules_Maths_Algo.md §IPC) ===
OCM_PORT_MAIN=26400
OCM_PORT_TEXT_ENCODER=26401
OCM_PORT_AUDIO_ENCODER=26402
OCM_PORT_VISION_ENCODER=26403
OCM_PORT_SPATIAL_ENCODER=26404
OCM_PORT_LSRA_CORE=26410
OCM_PORT_VERIFIER=26412
OCM_PORT_DICTIONARY=26414
OCM_PORT_TEACHER_API=26418
OCM_PORT_TRAIN_API=26419
OCM_PORT_COCKPIT=26420
OCM_VERIFIER_HOST=127.0.0.1

# === OCM-26400 — Chemins modèles / index ===
OCM_CHECKPOINT_PATH=/media/akone/SAVENVME2/Datasets/ocm26400/audio_unified_trained.pt
OCM_DOMAINS_SAVE_PATH=/media/akone/SAVENVME2/Datasets/ocm26400
OCM_RAG_INDEX_PATH=/media/akone/Dev/Dev_D/01_Dev_1/IA_Dev_D/12_Hermes/Recherches/MathsBase/.ocm_rag_index

# === Identité / branding OCM-26400 ===
OCM_COCKPIT_PROJECT_NAME=OCM-26400
VITE_OCM_COCKPIT_PROJECT_NAME=OCM-26400
OCM_COCKPIT_TAGLINE=Omni-Cognitive Mentalese — SpectralCoreBlock (FFT)
VITE_OCM_COCKPIT_TAGLINE=Omni-Cognitive Mentalese — SpectralCoreBlock (FFT)

# === Paramètres modèle SpectralCoreBlock (paradigme OCM-26400) ===
OCM_COCKPIT_VRAM_CAP_GB=3
VITE_OCM_COCKPIT_VRAM_CAP_GB=3
